# .env.cogni — this node's operator credential (copy to .env.cogni; gitignored via .env*)
# ─────────────────────────────────────────────────────────────────────────────
# v0 = the operator RBAC *developer* permission for THIS node.
#
# A registered-agent bearer is what exercises that permission: with it an agent
# can recall the cognition substrate, file an access request, and flight a
# nodeRef to candidate-a once the human owner approves the developer grant in the
# operator UI. The bearer can USE the grant; it can never approve itself.
#
# How to fill (canonical runbook: knowledge `node-launch-handoff`):
#   1. Register this agent against the production operator:
#        curl -sS -X POST https://cognidao.org/api/v1/agent/register \
#          -H 'content-type: application/json' \
#          --data '{"name":"<agent-or-workspace-name>"}'
#      Response: {"userId":"...","apiKey":"...","billingAccountId":"..."}
#   2. cp .env.cogni.example .env.cogni  and paste the values below.
#   3. Keep COGNI_API_KEY private. Show only COGNI_USER_ID to the human owner so
#      they can Approve the developer request in the node page → Agents → Approve.
# ─────────────────────────────────────────────────────────────────────────────

# Bearer used for cognition recall + nodeRef flight (Authorization: Bearer $COGNI_API_KEY).
# Consumed at session start by scripts/agent/session-cognition.sh.
COGNI_API_KEY=

# Agent identity. Give COGNI_USER_ID to the human owner for the RBAC approval;
# it is the `user:<agentUserId>` in the OpenFGA `developer node:<nodeId>` tuple.
COGNI_USER_ID=
COGNI_BILLING_ACCOUNT=

# The node this credential is scoped to (from the launch pack).
COGNI_NODE_ID=

# Operator cognition endpoint. Override for candidate/preview, e.g.
# https://<slug>-test.cognidao.org/api/v1/cognition
COGNI_COGNITION_URL=https://cognidao.org/api/v1/cognition
